---
import '../styles/global.css';
import Navbar from '../components/react/Navbar.jsx';
import Footer from '../components/layout/Footer.astro';
import FloatingEnquireButton from '../components/react/FloatingEnquireButton.jsx';
import ModalRoot from '../components/react/ModalRoot.jsx';
import SmoothScrollProvider from '../components/react/SmoothScrollProvider.jsx';

const { title = 'BSI Solutionz - Authorized Bajaj Indef Dealer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "BSI Solutionz",
        "description": "Authorized Bajaj Indef Dealer specializing in industrial cranes, hoists and material handling solutions",
        "url": "https://bsisolutionz.com",
        "telephone": "+91-9717897960",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "515, Vishal Chamber, Sector-18",
          "addressLocality": "Noida",
          "addressRegion": "Uttar Pradesh",
          "postalCode": "201301",
          "addressCountry": "IN"
        }
      }
    </script>
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-bsi-surface min-h-screen overflow-x-clip font-body text-bsi-primary">
    <SmoothScrollProvider client:load />
    <Navbar client:load pathname={Astro.url.pathname} />
    <main class="page-transition">
      <slot />
    </main>
    <FloatingEnquireButton client:load />
    <Footer />
    <ModalRoot client:load />
    <script is:inline>
      const ENQUIRY_EVENT = 'bsi:open-enquiry'
      const backToTopButton = document.querySelector('[data-back-to-top]')

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Element)) {
          return
        }

        const enquiryTrigger = event.target.closest('[data-open-enquiry]')
        if (!enquiryTrigger) {
          return
        }

        window.dispatchEvent(
          new CustomEvent(ENQUIRY_EVENT, {
            detail: {
              productName: enquiryTrigger.getAttribute('data-product-name') || '',
            },
          })
        )
      })

      if (backToTopButton) {
        backToTopButton.addEventListener('click', () => {
          if (window.__lenis && typeof window.__lenis.scrollTo === 'function') {
            window.__lenis.scrollTo(0, { duration: 1.2 })
            return
          }
          window.scrollTo({ top: 0, behavior: 'smooth' })
        })
      }
    </script>
  </body>
</html>
