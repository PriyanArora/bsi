---
import { CATEGORY_CATALOG } from '../../lib/productCatalog.js';
import { getCategoryTitleImage } from '../../lib/productImages.js';

const {
  categories: rawCategories = CATEGORY_CATALOG,
  showPlaceholderOnMissingImage = false,
  sortCategories = true
} = Astro.props;

const categories: Array<{ slug: string, categoryName: string, description: string, productsCount: number }> = rawCategories;

const visibleCategories: Array<{ slug: string, categoryName: string, description: string, productsCount: number }> = sortCategories
  ? [...categories].sort(
      (a, b) => b.productsCount - a.productsCount || a.categoryName.localeCompare(b.categoryName)
    )
  : categories;
---

<div class="grid grid-cols-1 gap-6 px-2 sm:px-4 md:grid-cols-2 md:px-8 lg:grid-cols-4 lg:gap-8 lg:px-16">
  {visibleCategories.map((category: { slug: string, categoryName: string, description: string, productsCount: number }) => {
    const categoryImage = getCategoryTitleImage(category);

    return (
      <a href={`/products/${category.slug}`} class="group block h-full">
        <article
          class="border-bsi-outline/30 bg-bsi-surface-lowest flex h-full min-h-116 flex-col rounded-none border p-6 md:p-7 shadow-[0_8px_30px_rgb(0,0,0,0.02)] transform-gpu transition-[transform,box-shadow] duration-200 ease group-hover:-translate-y-1.25 group-hover:scale-[1.01] group-hover:shadow-[0_14px_40px_rgb(0,0,0,0.08)]"
        >
          <div class="mb-5 flex h-44 items-center justify-center rounded-none border border-slate-200 bg-white p-3 md:h-48 lg:h-52">
            {categoryImage ? (
              <img
                src={categoryImage}
                alt={`${category.categoryName} title`}
                loading="lazy"
                class="h-full w-full object-contain"
              />
            ) : showPlaceholderOnMissingImage ? (
              <img
                src="/product-placeholder.svg"
                alt={`${category.categoryName} placeholder`}
                loading="lazy"
                class="h-full w-full object-contain"
              />
            ) : (
              <span class="text-bsi-primary/45 font-headline text-[3rem] font-extrabold uppercase tracking-tight">
                {category.categoryName
                  .split(' ')
                  .map((word: string) => word[0])
                  .join('')}
              </span>
            )}
          </div>

          <h3 class="font-headline text-bsi-primary mb-2 text-xl font-bold">{category.categoryName}</h3>
          <p class="text-bsi-secondary mb-8 text-sm leading-relaxed">{category.description}</p>

          <div class="mt-auto flex items-center justify-between gap-4 pt-2">
            <span class="text-bsi-secondary text-[10px] font-bold uppercase tracking-[0.2em]">
              {`${category.productsCount} OPTIONS`}
            </span>

            <div
              aria-hidden="true"
              class="bg-bsi-primary-container text-white flex h-10 w-10 items-center justify-center rounded-full transition-transform duration-300 group-hover:translate-x-1"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 12h12M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
        </article>
      </a>
    );
  })}
</div>
