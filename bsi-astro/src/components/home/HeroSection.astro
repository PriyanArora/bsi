---
const craneImg = '/og-products-placeholder.png';
---

<section class="hero-mobile-shell hero-gradient-wash section-pad relative flex min-h-screen w-full items-center overflow-x-clip overflow-y-hidden pt-(--bsi-navbar-height)">
  <div class="hero-layout relative z-10 w-full">
    <div class="hero-crane-wrap relative will-change-transform">
      <img
        src={craneImg}
        alt="BSI crane installation"
        loading="lazy"
        class="hero-crane-image ml-auto max-w-none object-contain"
      />
    </div>

    <div class="hero-text-anchor absolute left-3 z-20 sm:left-6 md:left-10 lg:left-16">
      <div class="hero-text-container">
        <h1 class="hero-title font-headline font-extrabold tracking-tight text-[#0D1F3C]">
          BSI Solutionz
        </h1>
        <p class="hero-text-description mt-4 text-base leading-[1.6] font-normal text-[#1F2F47] sm:text-[1.05rem]">
          We&apos;ve spent 10+ years making sure India never stops moving. Your one stop for Bajaj Indef electric hoists, rentals, and complete AMC care, Pan-India.
        </p>
      </div>
    </div>
  </div>
</section>
