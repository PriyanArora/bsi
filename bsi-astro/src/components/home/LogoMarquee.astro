---
import indianOilLogo from '../../assets/logos/IndianOilLogo.png';
import vardhmanLogo from '../../assets/logos/VardhmanLogo.png';
import unileverLogo from '../../assets/logos/UnileverLogo.png';
import toshibaLogo from '../../assets/logos/ToshibaLogo.png';
import thyssenkruppLogo from '../../assets/logos/ThyssenkruppLogo.png';
import nestleLogo from '../../assets/logos/NestleLogo.png';
import escortsKubotaLogo from '../../assets/logos/EscortsKubotaLogo.png';
import danoneLogo from '../../assets/logos/DanoneLogo.png';

const normalizeAsset = (asset: string | { src: string } | undefined) =>
  typeof asset === 'string' ? asset : asset?.src || '';

const industryLogos = [
  { src: normalizeAsset(indianOilLogo), label: 'Indian Oil' },
  { src: normalizeAsset(vardhmanLogo), label: 'Vardhman' },
  { src: normalizeAsset(unileverLogo), label: 'Unilever' },
  { src: normalizeAsset(toshibaLogo), label: 'Toshiba' },
  { src: normalizeAsset(thyssenkruppLogo), label: 'Thyssenkrupp' },
  { src: normalizeAsset(nestleLogo), label: 'Nestle' },
  { src: normalizeAsset(escortsKubotaLogo), label: 'Escorts Kubota' },
  { src: normalizeAsset(danoneLogo), label: 'Danone' }
];
---

<section class="section-pad border-bsi-outline/30 bg-[#F4F6F9] overflow-hidden border-y">
  <div class="mx-auto mt-0 mb-9 max-w-7xl px-6 md:px-9">
    <h3 class="text-bsi-secondary text-center text-xs font-semibold uppercase tracking-[0.25em] md:text-left">
      Trusted by Industries Across the Region
    </h3>
  </div>

  <div class="flex overflow-hidden">
    <div class="animate-bsi-marquee flex min-w-max gap-8 whitespace-nowrap px-6 sm:gap-10 sm:px-8 lg:gap-14">
      <div class="flex items-center gap-8 sm:gap-10 lg:gap-14">
        {industryLogos.map((item) => (
          <div class="flex h-16 w-36 items-center justify-center sm:h-18 sm:w-40 lg:h-20 lg:w-44">
            <img
              src={item.src}
              alt={`${item.label} logo`}
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </div>
        ))}
      </div>
      <div class="flex items-center gap-8 sm:gap-10 lg:gap-14">
        {industryLogos.map((item) => (
          <div class="flex h-16 w-36 items-center justify-center sm:h-18 sm:w-40 lg:h-20 lg:w-44">
            <img
              src={item.src}
              alt={`${item.label} logo`}
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
