---
const testimonials = [
  {
    quote:
      'The EOT crane installation by BSI Solutionz was seamless. Their engineering team understood our headroom constraints perfectly.',
    name: 'Arun Varma',
    role: 'Plant Manager, TechMech Industries'
  },
  {
    quote:
      'Upgrading our hoists to Bajaj Indef through BSI has reduced our maintenance downtime by nearly 40%.',
    name: 'Sanjay Mehta',
    role: 'Operations Head, SteelCraft Ltd.'
  },
  {
    quote:
      'Professional approach, technical depth, and excellent post-sales support. BSI is our go-to for material handling.',
    name: 'Rahul Deshmukh',
    role: 'Procurement Manager, Global Logistics'
  }
];
---

<section class="section-pad relative overflow-hidden bg-[#F4F6F9] text-[#0D1F3C]">
  <div class="absolute inset-0 bg-[radial-gradient(#d5dce8_1px,transparent_1px)] bg-size-[16px_16px] opacity-30 md:bg-size-[20px_20px]" />

  <div class="relative z-10 mx-auto max-w-7xl px-6 md:px-8">
    <h2 class="font-headline mb-10 text-2xl font-bold text-[#0D1F3C] sm:mb-12 sm:text-3xl">Trusted by Heavy Industry Leaders</h2>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((item) => (
        <article class="rounded-lg border border-[#d8dee8] bg-white p-6 shadow-sm sm:p-8">
          <p class="text-sm leading-relaxed italic text-[#4A5568]">&quot;{item.quote}&quot;</p>
          <div class="mt-6 flex items-center gap-4">
            <div class="bg-bsi-accent h-10 w-10 rounded-full" />
            <div>
              <p class="text-sm font-bold text-[#0D1F3C]">{item.name}</p>
              <p class="text-xs text-[#6b7280]">{item.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
