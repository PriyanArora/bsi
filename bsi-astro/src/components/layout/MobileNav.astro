---
const { pathname = '/' } = Astro.props;

const navLinks = [
  { label: 'Home', to: '/' },
  { label: 'Products', to: '/products' },
  { label: 'About', to: '/about' },
  { label: 'Contact', to: '/contact' }
];

const isOpen = false;
const overlayClass = `fixed inset-0 z-130 bg-black/45 transition-opacity duration-200 ${
  isOpen ? 'opacity-100' : 'pointer-events-none opacity-0'
}`;
const panelClass = `fixed top-0 right-0 z-140 flex h-full w-[90%] max-w-[20rem] flex-col border-l border-[#D8DEE8] bg-[#F4F6F9] p-5 shadow-2xl transition-transform duration-300 ease-out sm:w-[84%] sm:max-w-sm sm:p-6 ${
  isOpen ? 'translate-x-0' : 'translate-x-full'
}`;
const isActive = (to: string) => pathname === to;
---

<div aria-hidden="true" class={overlayClass} />

<aside
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  class={panelClass}
>
  <div class="mb-6 flex items-center justify-between">
    <h2 class="font-headline text-lg font-bold text-[#0D1F3C]">Menu</h2>
    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded border border-[#C7D0DD] bg-white text-[#0D1F3C]"
      aria-label="Close menu"
    >
      X
    </button>
  </div>

  <nav class="flex flex-col gap-3">
    {navLinks.map(({ label, to }) => (
      <a
        href={to}
        class={`rounded px-3 py-2 font-headline text-sm font-semibold ${
          isActive(to) ? 'bg-[#FFD100] text-[#0D1F3C]' : 'text-[#0D1F3C] hover:bg-white'
        }`}
      >
        {label}
      </a>
    ))}
  </nav>

  <button
    type="button"
    class="mt-6 inline-flex w-full justify-center rounded-full border border-[#D2DAE6] bg-[#0D2E5A] px-4 py-2.5 font-headline text-sm font-bold text-white transition-colors duration-200 hover:bg-[#12386B]"
  >
    Help me choose
  </button>
</aside>
