---
const quickLinks = [
  { label: 'Products', to: '/products' },
  { label: 'About Us', to: '/about' },
  { label: 'Contact Us', to: '/contact' }
];

const legalLinks = [
  { label: 'Privacy Policy', to: '/privacy-policy' }
];
---

<footer class="w-full border-t border-[#223554] bg-[#0F1E35]">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-6 py-12 sm:grid-cols-2 sm:px-8 sm:py-14 lg:grid-cols-4 lg:gap-12 lg:py-16">
    <div class="md:col-span-1">
      <div class="font-headline mb-6 text-lg font-bold text-slate-100">BSI Solutionz</div>
      <p class="text-sm leading-relaxed text-slate-300">
        Authorized Bajaj Indef Dealer and your partner in premium industrial material handling systems and AMC care.
      </p>
    </div>

    <div>
      <h5 class="mb-6 font-bold text-slate-100">Quick Links</h5>
      <ul class="flex flex-col gap-4">
        {quickLinks.map(({ label, to }) => (
          <li>
            <a href={to} class="text-sm text-slate-300 transition-colors hover:text-[#FFD100]">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h5 class="mb-6 font-bold text-slate-100">Legal</h5>
      <ul class="flex flex-col gap-4">
        {legalLinks.map(({ label, to }) => (
          <li>
            <a href={to} class="text-sm text-slate-300 transition-colors hover:text-[#FFD100]">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h5 class="mb-6 font-bold text-slate-100">Contact Us</h5>
      <p class="mb-4 text-sm text-slate-300">515, Vishal Chamber, Sector-18, Noida, Gautam Buddha Nagar, U.P-201301</p>
      <p class="mb-3 text-sm text-slate-300">bsisolutionz@gmail.com</p>
      <p class="text-sm text-slate-300">+91 9717897960</p>
    </div>
  </div>

  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-4 border-t border-[#223554] px-6 py-6 sm:px-8 sm:grid-cols-2 md:items-center md:py-8 lg:grid-cols-4">
    <p class="text-xs text-slate-300 sm:col-span-2 lg:col-span-3">© 2026 BSI Solutionz- All rights reserved</p>
    <button
      type="button"
      data-back-to-top
      class="flex items-center gap-2 text-xs font-medium text-slate-100 hover:text-[#FFD100] sm:justify-self-end lg:col-start-4 lg:justify-self-start"
    >
      Back to Top
      <span class="material-symbols-outlined text-sm">arrow_upward</span>
    </button>
  </div>
</footer>
