---
const aboutTestimonials = [
  {
    quote:
      'BSI Solutionz delivered a crane modernization plan that improved throughput and reduced downtime across our plant.',
    person: 'Plant Operations Lead'
  },
  {
    quote:
      'Their team combines technical depth with practical deployment support. We rely on them for every expansion phase.',
    person: 'Logistics Program Manager'
  }
];
---

<section class="mt-14 mx-2 rounded-2xl bg-bsi-primary p-6 text-white sm:mt-16 sm:mx-4 sm:p-8 md:mx-8 md:p-10 lg:mx-16">
  <div class="mb-8 flex items-center justify-between gap-4">
    <h3 class="font-headline text-2xl font-bold md:text-3xl">Client Voice</h3>
    <span class="text-bsi-accent text-xs font-bold uppercase tracking-[0.2em]">Proof of trust</span>
  </div>

  <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {aboutTestimonials.map((item) => (
      <article class="rounded-xl border border-white/15 bg-white/5 p-5">
        <p class="text-sm leading-relaxed text-slate-200">&quot;{item.quote}&quot;</p>
        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.14em] text-white/75">{item.person}</p>
      </article>
    ))}
  </div>
</section>
